PORT=8081

# Postgres + pgvector connection string. Examples:
#   Local docker (see ../docker-compose.yml):
#     postgresql://postgres:postgres@localhost:5433/camera_rag
#   Supabase / Neon: use their pooled connection URI (remote host → SSL auto-on)
DATABASE_URL=postgresql://user:pass@host:5432/db

# SSL mode: auto (on for remote hosts, off for localhost) | true | false
DATABASE_SSL=auto

# Gemini (free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash

# CORS allowlist for the client (comma-separated). Add your Vercel URL in prod.
CLIENT_ORIGIN=http://localhost:5173
